{
  "name": "@dog-health/bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram Bot for Dog Health Assistant.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run build && BOT_DRY_RUN=true node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "grammy": "1.43.0"
  },
  "devDependencies": {
    "tsx": "4.19.4"
  }
}
