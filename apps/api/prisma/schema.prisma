generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DogSex {
  female
  male
}

enum HealthEventType {
  vaccination
  revaccination
  deworming
  tick_treatment
  flea_treatment
  weight_tracking
  vet_visit
  surgery
  other
}

enum ReminderType {
  heat_cycle
  health_event
  custom
}

enum NotificationType {
  health_event_reminder
  heat_cycle_check
  heat_cycle_forecast
}

enum NotificationStatus {
  unread
  read
}

enum SymptomRiskLevel {
  low
  medium
  high
}

enum KnowledgeCategory {
  proestrus
  estrus
  diestrus
  false_pregnancy
  postpartum
  vet_warning_signs
}

model User {
  id         String   @id @default(cuid())
  telegramId String   @unique
  firstName  String?
  username   String?
  createdAt  DateTime @default(now())

  dogs          Dog[]
  notifications Notification[]

  @@map("users")
}

model Dog {
  id         String    @id @default(cuid())
  userId     String
  name       String
  breed      String?
  sex        DogSex
  birthDate  DateTime?
  weight     Decimal?  @db.Decimal(6, 2)
  color      String?
  sterilized Boolean   @default(false)
  notes      String?
  createdAt  DateTime  @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  heatCycles     HeatCycle[]
  healthEvents   HealthEvent[]
  reminders      Reminder[]
  symptomReports SymptomReport[]
  notifications  Notification[]

  @@index([userId])
  @@map("dogs")
}

model HeatCycle {
  id        String    @id @default(cuid())
  dogId     String
  startDate DateTime
  endDate   DateTime?
  duration  Int?
  predicted Boolean   @default(false)
  notes     String?
  createdAt DateTime  @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@index([dogId])
  @@index([startDate])
  @@map("heat_cycles")
}

model HealthEvent {
  id               String          @id @default(cuid())
  dogId            String
  type             HealthEventType
  title            String
  eventDate        DateTime
  nextReminderDate DateTime?
  notes            String?
  createdAt        DateTime        @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@index([dogId])
  @@index([eventDate])
  @@index([nextReminderDate])
  @@map("health_events")
}

model Reminder {
  id           String       @id @default(cuid())
  dogId        String
  type         ReminderType
  reminderDate DateTime
  sent         Boolean      @default(false)
  createdAt    DateTime     @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@index([dogId])
  @@index([reminderDate])
  @@index([sent])
  @@map("reminders")
}

model Notification {
  id                String             @id @default(cuid())
  userId            String
  dogId             String?
  type              NotificationType
  title             String
  message           String
  status            NotificationStatus @default(unread)
  scheduledAt       DateTime
  readAt            DateTime?
  telegramSentAt    DateTime?
  telegramError     String?
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  dog  Dog? @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@unique([userId, type, relatedEntityType, relatedEntityId, scheduledAt], map: "notifications_userId_type_relatedEntityType_relatedEntityId_key")
  @@index([userId])
  @@index([dogId])
  @@index([status])
  @@index([scheduledAt])
  @@index([telegramSentAt])
  @@map("notifications")
}

model SymptomReport {
  id         String            @id @default(cuid())
  dogId      String
  text       String
  aiAnalysis String?
  riskLevel  SymptomRiskLevel?
  createdAt  DateTime          @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@index([dogId])
  @@index([riskLevel])
  @@map("symptom_reports")
}

model KnowledgeArticle {
  id        String            @id @default(cuid())
  title     String
  category  KnowledgeCategory
  content   String
  createdAt DateTime          @default(now())

  @@index([category])
  @@map("knowledge_articles")
}
